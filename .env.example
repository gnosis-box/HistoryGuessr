# History Guessr — Circles (https://docs.aboutcircles.com/)

# On-chain HIST group (after deploy)
# VITE_HIST_GROUP_ADDRESS=0xYourHistoryGuessrGroupAddress

# --- Option A (simple) : nouveau wallet MetaMask dédié, pas de clé du Safe ---
# OPERATOR_PRIVATE_KEY=0x<64_hex>   # only in .env.local — never commit
# npm run hist:register-group

# --- Option B : ton Safe Circles Lenormand + signataire MetaMask ---
# SAFE_ADDRESS=0xD55a912aF5639a6769AE5c1894C0c7BFB5Bf539E
# SIGNER_PRIVATE_KEY=0x<64_hex_MetaMask_signer>   # only in .env.local
# npm run hist:register-group-safe

# HIST_GROUP=0x...            # same as VITE_HIST_GROUP_ADDRESS (hist:check / hist:distribute)
# GNOSIS_RPC_URL=https://rpc.gnosischain.com

# Optional
# VITE_APP_URL=https://history-guessr.vercel.app
# VITE_DEV_RELAX_TRUST=true
